<Window x:Class="DecryptTool.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DecryptTool"
        Width="980"
        Height="720"
        MinWidth="860"
        MinHeight="620"
        Background="#F3EFE6">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="20"
                CornerRadius="18"
                Background="#1E3A34">
            <StackPanel>
                <TextBlock FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#F6F0E4"
                           Text="DecryptTool UI" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="14"
                           Foreground="#D7E2DC"
                           Text="QA-friendly cookie decryption powered by the same core service as tok." />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Padding="20"
                CornerRadius="18"
                Background="#FFFDFC">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Margin="0,0,0,6"
                               FontWeight="SemiBold"
                               Foreground="#22322E"
                               Text="Encrypted Cookie" />
                    <TextBox Height="120"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Text="{Binding Cookie, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Margin="0,0,0,6"
                               FontWeight="SemiBold"
                               Foreground="#22322E"
                               Text="Environment" />
                    <ComboBox Height="36"
                              ItemsSource="{Binding Environments}"
                              SelectedItem="{Binding SelectedEnvironment}" />
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock Margin="0,0,0,6"
                               FontWeight="SemiBold"
                               Foreground="#22322E"
                               Text="Fingerprint" />
                    <TextBox Height="36"
                             Text="{Binding Fingerprint, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <Border Grid.Row="2"
                        Grid.Column="2"
                        Padding="12"
                        CornerRadius="14"
                        Background="#EEF3F0">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="#22322E"
                                   Text="Defaults" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#415852"
                                   Text="Environment defaults to Dev if no saved value exists." />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#415852"
                                   Text="The last fingerprint is saved locally for the next launch." />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="4"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Orientation="Horizontal">
                    <Button Width="140"
                            Height="40"
                            Margin="0,0,12,0"
                            Padding="18,8"
                            Background="#BE5A38"
                            Foreground="White"
                            BorderThickness="0"
                            Click="DecryptButton_Click"
                            Content="Decrypt" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#415852"
                               Text="{Binding Status}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Padding="20"
                CornerRadius="18"
                Background="#FFFDFC">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#22322E"
                           Text="Decrypted Output" />

                <TextBox Grid.Row="2"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         Text="{Binding Output}" />
            </Grid>
        </Border>
    </Grid>
</Window>
