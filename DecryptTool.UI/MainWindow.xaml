<Window x:Class="DecryptTool.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DecryptTool.UI.Controls"
        xmlns:models="clr-namespace:DecryptTool.UI.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tok UI"
        Icon="Assets/tok-ui.png"
        Width="1180"
        Height="820"
        MinWidth="1020"
        MinHeight="740"
        FontFamily="Segoe UI"
        FontSize="14"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#22322E" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#22322E" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#22322E" />
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>
        <Style x:Key="CodeBox" TargetType="TextBox" BasedOn="{StaticResource InputBox}">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="AcceptsReturn" Value="True" />
        </Style>
        <DataTemplate x:Key="IconButtonContentTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           FontSize="15"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                           Text="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Tag}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                           Text="{Binding}" />
            </StackPanel>
        </DataTemplate>
        <Style x:Key="IconPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="ContentTemplate" Value="{StaticResource IconButtonContentTemplate}" />
        </Style>
        <Style x:Key="IconSecondaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="ContentTemplate" Value="{StaticResource IconButtonContentTemplate}" />
        </Style>
        <Style x:Key="IconSubtleButton" TargetType="Button" BasedOn="{StaticResource SubtleButton}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="ContentTemplate" Value="{StaticResource IconButtonContentTemplate}" />
        </Style>
        <Style x:Key="InfoBadge" TargetType="Border">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="#DBEAFE" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTipService.ShowDuration" Value="60000" />
        </Style>
        <Style x:Key="InfoBadgeText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe UI Symbol" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1D4ED8" />
            <Setter Property="Text" Value="i" />
        </Style>
        <Style x:Key="GuidanceToolTip" TargetType="ToolTip">
            <Setter Property="MaxWidth" Value="380" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#BFDBFE" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="HasDropShadow" Value="True" />
        </Style>
        <DataTemplate x:Key="ExpirationToolTipContentTemplate" DataType="{x:Type models:ExpirationToolTipInfo}">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               Text="{Binding Header}" />
                    <Border Margin="8,0,0,0"
                            Padding="8,3"
                            CornerRadius="999"
                            Background="{Binding StatusBrush}">
                        <TextBlock FontSize="12.5"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="{Binding StatusText}" />
                    </Border>
                </StackPanel>
                <Border Margin="0,8,0,0"
                        Padding="9,7"
                        CornerRadius="8"
                        Background="#EFF6FF">
                    <StackPanel>
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#1E3A8A"
                                   Text="Expires (Local)" />
                        <TextBlock Margin="0,3,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A"
                                   Text="{Binding ExpiresLocalText}" />
                        <TextBlock Margin="0,3,0,0"
                                   FontSize="11.5"
                                   Foreground="#475569"
                                   Text="{Binding ExpiresUtcText, StringFormat=UTC: {0}}" />
                    </StackPanel>
                </Border>
                <Border Margin="0,6,0,0"
                        Padding="9,7"
                        CornerRadius="8"
                        Background="#F0FDF4">
                    <StackPanel>
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#166534"
                                   Text="Time Remaining" />
                        <TextBlock Margin="0,3,0,0"
                                   Foreground="#0F172A"
                                   Text="{Binding RemainingText}" />
                    </StackPanel>
                </Border>
                <Border Margin="0,6,0,0"
                        Padding="9,7"
                        CornerRadius="8"
                        Background="#FFF7ED">
                    <StackPanel>
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#9A3412"
                                   Text="Token Lifetime" />
                        <TextBlock Margin="0,3,0,0"
                                   Foreground="#0F172A"
                                   Text="{Binding TokenLifetimeText}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>
        <Style x:Key="CompareCookieExpText" TargetType="TextBlock" BasedOn="{StaticResource CompareGridText}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Claim}" Value="exp">
                    <Setter Property="Foreground" Value="#1D4ED8" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="TextDecorations" Value="Underline" />
                    <Setter Property="Tag"
                            Value="{Binding DataContext.CompareCookieExpirationInfo, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Setter Property="ToolTip">
                        <Setter.Value>
                            <ToolTip Style="{StaticResource GuidanceToolTip}"
                                     DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}"
                                     Content="{Binding}"
                                     ContentTemplate="{StaticResource ExpirationToolTipContentTemplate}" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CompareAuthExpText" TargetType="TextBlock" BasedOn="{StaticResource CompareGridText}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Claim}" Value="exp">
                    <Setter Property="Foreground" Value="#1D4ED8" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="TextDecorations" Value="Underline" />
                    <Setter Property="Tag"
                            Value="{Binding DataContext.CompareAuthExpirationInfo, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Setter Property="ToolTip">
                        <Setter.Value>
                            <ToolTip Style="{StaticResource GuidanceToolTip}"
                                     DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}"
                                     Content="{Binding}"
                                     ContentTemplate="{StaticResource ExpirationToolTipContentTemplate}" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CookieClaimExpText" TargetType="TextBlock" BasedOn="{StaticResource CompareGridText}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Claim}" Value="exp">
                    <Setter Property="Foreground" Value="#1D4ED8" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="TextDecorations" Value="Underline" />
                    <Setter Property="Tag"
                            Value="{Binding DataContext.CookieExpirationInfo, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Setter Property="ToolTip">
                        <Setter.Value>
                            <ToolTip Style="{StaticResource GuidanceToolTip}"
                                     DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}"
                                     Content="{Binding}"
                                     ContentTemplate="{StaticResource ExpirationToolTipContentTemplate}" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="InspectAuthExpText" TargetType="TextBlock" BasedOn="{StaticResource CompareGridText}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Claim}" Value="exp">
                    <Setter Property="Foreground" Value="#1D4ED8" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="TextDecorations" Value="Underline" />
                    <Setter Property="Tag"
                            Value="{Binding DataContext.JwtInspectExpirationInfo, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Setter Property="ToolTip">
                        <Setter.Value>
                            <ToolTip Style="{StaticResource GuidanceToolTip}"
                                     DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}"
                                     Content="{Binding}"
                                     ContentTemplate="{StaticResource ExpirationToolTipContentTemplate}" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="54"
                                Height="54"
                                Margin="0,0,14,0"
                                CornerRadius="27"
                                Background="#DBEAFE">
                            <Image Width="38"
                                   Height="38"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Source="Assets/tok-ui.png" />
                        </Border>
                        <StackPanel>
                            <TextBlock FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Text="Tok UI" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="15"
                                       Foreground="#4B5563"
                                       Text="Copy from Network. Understand instantly." />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Border Style="{StaticResource StatusPill}"
                            Background="{Binding StatusBrush}"
                            VerticalAlignment="Top">
                        <TextBlock Style="{StaticResource StatusPillText}"
                                   Foreground="{Binding LightTextBrushValue}"
                                   Text="{Binding StatusText}" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Padding="18"
                AllowDrop="True"
                PreviewDragOver="AutoDetectDropTarget_PreviewDragOver"
                Drop="AutoDetectDropTarget_Drop">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="170" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Grid HorizontalAlignment="Left"
                          MaxWidth="980">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource SectionTitle}"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="Paste cookies, JWTs, requests, or HAR files from DevTools to inspect, decode, and compare in seconds." />
                        <Border Grid.Column="1"
                                Style="{StaticResource InfoBadge}"
                                Margin="0,0,0,0"
                                VerticalAlignment="Top">
                            <Border.ToolTip>
                                <ToolTip Style="{StaticResource GuidanceToolTip}">
                                    <StackPanel>
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="#0F172A"
                                                   Text="Start from DevTools" />
                                        <Border Margin="0,10,0,0"
                                                Padding="10"
                                                CornerRadius="8"
                                                Background="#F8FAFC">
                                            <TextBlock TextWrapping="Wrap"
                                                       Foreground="#1F2937">
                                                <Run FontWeight="SemiBold" Text="Cookie:" />
                                                <Run Text=" paste the full " />
                                                <Run FontWeight="SemiBold" Text="encinfo" />
                                                <Run Text=" cookie from Application/Storage, or copy the Cookie header from the Network tab." />
                                            </TextBlock>
                                        </Border>
                                        <Border Margin="0,10,0,0"
                                                Padding="10"
                                                CornerRadius="8"
                                                Background="#EFF6FF">
                                            <TextBlock TextWrapping="Wrap"
                                                       Foreground="#1E3A8A">
                                                <Run FontWeight="SemiBold" Text="JWT:" />
                                                <Run Text=" use " />
                                                <Run FontWeight="SemiBold" Text="Copy as cURL" />
                                                <Run Text=" or " />
                                                <Run FontWeight="SemiBold" Text="Copy as fetch" />
                                                <Run Text=" from the Network tab instead of hunting for the bearer token manually." />
                                            </TextBlock>
                                        </Border>
                                        <Border Margin="0,8,0,0"
                                                Padding="10"
                                                CornerRadius="8"
                                                Background="#F0FDF4">
                                            <TextBlock TextWrapping="Wrap"
                                                       Foreground="#166534">
                                                <Run FontWeight="SemiBold" Text="Decrypt ENC:" />
                                                <Run Text=" paste the page URL, API URL, request body, or response body that already contains the " />
                                                <Run FontWeight="SemiBold" Text="ENC" />
                                                <Run Text=" value." />
                                            </TextBlock>
                                        </Border>
                                        <Border Margin="0,8,0,0"
                                                Padding="10"
                                                CornerRadius="8"
                                                Background="#FFF7ED">
                                            <TextBlock TextWrapping="Wrap"
                                                       Foreground="#9A3412">
                                                <Run FontWeight="SemiBold" Text="Cookie vs JWT:" />
                                                <Run Text=" export a " />
                                                <Run FontWeight="SemiBold" Text="HAR" />
                                                <Run Text=" from the Network tab when you want the app to pull the cookie, JWT, and compare data for you." />
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </ToolTip>
                            </Border.ToolTip>
                            <TextBlock Style="{StaticResource InfoBadgeText}" />
                        </Border>
                    </Grid>
                    <controls:FloatingLabelTextBox Height="96"
                                                   SelectAllOnFocus="True"
                                                   Label="Paste or drop a value"
                                                   AcceptsReturn="True"
                                                   TextWrapping="Wrap"
                                                   VerticalScrollBarVisibility="Auto"
                                                   Text="{Binding AutoDetectInput, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <Button Grid.Column="2"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource PrimaryButton}"
                        Click="AutoDetectButton_Click"
                        Content="Analyze Input" />

                <Button Grid.Column="4"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource SecondaryButton}"
                        Click="BrowseHarButton_Click"
                        Content="Browse HAR" />
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Style="{StaticResource CardStyle}"
                Padding="24">
            <TabControl SelectedIndex="{Binding SelectedTabIndex}">
                <TabItem Header="Cookie">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <controls:FloatingLabelTextBox Height="120"
                                                               Label="Encrypted Cookie"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding CookieInput, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <controls:FloatingLabelTextBox Height="64"
                                                               Label="Fingerprint"
                                                               Text="{Binding Fingerprint, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Margin="2,8,0,0"
                                            Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource BodyText}"
                                               FontSize="13"
                                               Foreground="#64748B"
                                               VerticalAlignment="Center"
                                               Text="{Binding FingerprintSource}" />
                                    <Border Style="{StaticResource InfoBadge}"
                                            Margin="8,0,0,0">
                                        <Border.ToolTip>
                                            <ToolTip Style="{StaticResource GuidanceToolTip}">
                                                <TextBlock TextWrapping="Wrap">
                                                    <Run FontWeight="SemiBold" Text="Cookie tip:" />
                                                    <Run Text=" leave Fingerprint blank to use " />
                                                    <Run FontWeight="SemiBold" Text="TOK_COOKIE_FINGERPRINT" />
                                                    <Run Text=". This tab is best when you already have just the encrypted cookie value." />
                                                </TextBlock>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource InfoBadgeText}" />
                                    </Border>
                                </StackPanel>
                                <controls:FloatingLabelComboBox Height="64"
                                                                Label="Environment"
                                                                ItemsSource="{Binding Environments}"
                                                                SelectedItem="{Binding SelectedEnvironment}" />
                            </StackPanel>

                            <Grid Grid.Row="2"
                                  Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Style="{StaticResource PrimaryButton}"
                                        IsEnabled="{Binding CanDecryptCookie}"
                                        Click="CookieDecryptButton_Click"
                                        Content="{Binding CookieActionText}" />
                                <Button Grid.Column="2"
                                        Style="{StaticResource SecondaryButton}"
                                        IsEnabled="{Binding CanSendCookieToCompare}"
                                        Click="SendCookieToCompareButton_Click"
                                        Content="Send to Cookie vs JWT" />
                            </Grid>

                            <Grid Grid.Row="4"
                                  Grid.ColumnSpan="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <controls:FloatingLabelTextBox Grid.Row="0"
                                                               Grid.ColumnSpan="3"
                                                               Height="120"
                                                               Label="Extracted JWT"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               IsReadOnly="True"
                                                               Text="{Binding CookieExtractedJwt, Mode=OneWay}" />

                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Header" />
                                    <controls:JsonViewer Margin="0,10,0,0"
                                                         MinHeight="180"
                                                         JsonText="{Binding CookieHeaderJson, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Style="{StaticResource SectionTitle}"
                                               Text="Cookie Claims" />
                                    <DataGrid Margin="0,10,0,0"
                                              MinHeight="420"
                                              AutoGenerateColumns="False"
                                              ItemsSource="{Binding CookieClaimRows}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Claim"
                                                                Binding="{Binding Claim}"
                                                                Width="0.95*"
                                                                ElementStyle="{StaticResource CompareGridText}" />
                                            <DataGridTemplateColumn Header="Cookie"
                                                                    Width="1.45*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Style="{StaticResource CookieClaimExpText}"
                                                                   Text="{Binding Value}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="JWT">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <controls:FloatingLabelTextBox Height="110"
                                                                   Label="JWT"
                                                                   AcceptsReturn="True"
                                                                   TextWrapping="Wrap"
                                                                   VerticalScrollBarVisibility="Auto"
                                                                   Text="{Binding JwtInspectInput, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <controls:FloatingLabelTextBox Height="64"
                                                                   Label="Encryption Key"
                                                                   Text="{Binding JwtInspectEncryptionKey, UpdateSourceTrigger=PropertyChanged}" />
                                    <StackPanel Margin="2,8,0,0"
                                                Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource BodyText}"
                                                   FontSize="13"
                                                   Foreground="#64748B"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding JwtInspectKeySource}" />
                                        <Border Style="{StaticResource InfoBadge}"
                                                Margin="8,0,0,0">
                                            <Border.ToolTip>
                                                <ToolTip Style="{StaticResource GuidanceToolTip}">
                                                    <TextBlock TextWrapping="Wrap">
                                                        <Run FontWeight="SemiBold" Text="JWT tip:" />
                                                        <Run Text=" paste the full fetch/cURL request or an Authorization header and Tok will pull the bearer token into this tab for you." />
                                                    </TextBlock>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Style="{StaticResource InfoBadgeText}" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>

                                <Button MinWidth="168"
                                        Style="{StaticResource PrimaryButton}"
                                        IsEnabled="{Binding CanInspectJwt}"
                                        Click="JwtInspectButton_Click"
                                        Content="{Binding InspectActionText}" />

                                <Button Grid.Column="2"
                                        MinWidth="192"
                                        Style="{StaticResource SecondaryButton}"
                                        IsEnabled="{Binding CanSendInspectToCompare}"
                                        Click="SendInspectToCompareButton_Click"
                                        Content="Send to Cookie vs JWT" />

                                <Border Grid.Column="5"
                                        Style="{StaticResource StatusPill}"
                                        Background="{Binding JwtInspectExpiryBadgeBrush}"
                                        VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource StatusPillText}"
                                               Foreground="{Binding LightTextBrushValue}"
                                               Text="{Binding JwtInspectExpiryBadgeText}" />
                                </Border>
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.42*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1.3*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Header" />
                                    <controls:JsonViewer Margin="0,10,0,0"
                                                         MinHeight="240"
                                                         JsonText="{Binding JwtInspectHeader, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="JWT Claims" />
                                    <DataGrid Margin="0,10,0,0"
                                              MinHeight="320"
                                              AutoGenerateColumns="False"
                                              ItemsSource="{Binding JwtInspectClaimRows}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Claim"
                                                                Binding="{Binding Claim}"
                                                                Width="0.72*"
                                                                ElementStyle="{StaticResource CompareGridText}" />
                                            <DataGridTemplateColumn Header="JWT Clear"
                                                                    Width="1.18*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Style="{StaticResource InspectAuthExpText}"
                                                                   Text="{Binding AuthValue}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="JWT Encrypted"
                                                                    Width="1.18*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Style="{StaticResource InspectAuthExpText}"
                                                                   Text="{Binding AuthEncryptedValue}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Cookie vs JWT">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Load from HAR" />
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource BodyText}"
                                           Foreground="#5B6D68"
                                           Text="Browse to a HAR file or drop it into Analyze Input to extract the auth JWT and decrypted cookie automatically." />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <controls:FloatingLabelTextBox Grid.Column="0"
                                                                   Height="64"
                                                                   Label="HAR File Path"
                                                                   Text="{Binding CompareHarFilePath, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2"
                                            MinWidth="132"
                                            Margin="0,22,0,0"
                                            VerticalAlignment="Top"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="BrowseHarFromCompareButton_Click"
                                            Content="Browse HAR" />
                                </Grid>
                                <controls:FloatingLabelTextBox Height="64"
                                                               Label="HAR Encryption Key"
                                                               Text="{Binding CompareHarEncryptionKey, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Margin="2,8,0,0"
                                            Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource BodyText}"
                                               FontSize="13"
                                               Foreground="#64748B"
                                               VerticalAlignment="Center"
                                               Text="{Binding CompareHarKeySource}" />
                                    <Border Style="{StaticResource InfoBadge}"
                                            Margin="8,0,0,0">
                                        <Border.ToolTip>
                                            <ToolTip Style="{StaticResource GuidanceToolTip}">
                                                <TextBlock TextWrapping="Wrap">
                                                    <Run FontWeight="SemiBold" Text="HAR workflow:" />
                                                    <Run Text=" Tok uses the HAR encryption key to resolve the fingerprint, decrypt the cookie, extract the auth JWT, and prepare the comparison in one step." />
                                                </TextBlock>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource InfoBadgeText}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Margin="2,10,0,0"
                                           Style="{StaticResource BodyText}"
                                           FontSize="13"
                                           Foreground="#64748B"
                                           Text="{Binding CompareHarSummary}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <controls:FloatingLabelTextBox Height="110"
                                                               Label="Cookie JWT / Encrypted Cookie"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding CompareCookieJwt, UpdateSourceTrigger=PropertyChanged}" />

                                <controls:FloatingLabelTextBox Height="110"
                                                               Label="JWT"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding CompareAuthJwt, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <controls:FloatingLabelTextBox Height="64"
                                                               Label="Fingerprint"
                                                               Text="{Binding Fingerprint, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="2,8,0,0"
                                           Style="{StaticResource BodyText}"
                                           FontSize="13"
                                           Foreground="#64748B"
                                           Text="{Binding FingerprintSource}" />
                                <controls:FloatingLabelComboBox Height="64"
                                                                Label="Environment"
                                                                ItemsSource="{Binding Environments}"
                                                                SelectedItem="{Binding SelectedEnvironment}" />
                                <Button Margin="0,18,0,0"
                                        Style="{StaticResource PrimaryButton}"
                                        IsEnabled="{Binding CanCompareTokens}"
                                        Click="CompareTokensButton_Click"
                                        Content="{Binding CompareActionText}" />
                            </StackPanel>

                            <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <CheckBox HorizontalAlignment="Right"
                                          IsChecked="{Binding ShowDifferencesOnly}"
                                          Content="Show Differences Only" />
                            </Grid>

                            <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Claim Comparison" />
                                <DataGrid Margin="0,10,0,0"
                                          MinHeight="280"
                                          AutoGenerateColumns="False"
                                          ItemsSource="{Binding CompareRows}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Claim"
                                                            Binding="{Binding Claim}"
                                                            Width="0.82*"
                                                            ElementStyle="{StaticResource CompareGridText}" />
                                        <DataGridTemplateColumn Header="Cookie"
                                                                Width="1.18*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Style="{StaticResource CompareCookieExpText}"
                                                               Text="{Binding CookieValue}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="JWT Clear"
                                                                Width="1.18*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Style="{StaticResource CompareAuthExpText}"
                                                               Text="{Binding AuthValue}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="JWT Raw"
                                                                Width="1.18*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Style="{StaticResource CompareAuthExpText}"
                                                               Text="{Binding AuthEncryptedValue}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Status"
                                                                Width="96"
                                                                HeaderStyle="{StaticResource CompareStatusHeader}"
                                                                CellStyle="{StaticResource CompareStatusCell}">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource StatusChip}"
                                                            Background="{Binding StatusBrush}"
                                                            HorizontalAlignment="Center">
                                                        <TextBlock Style="{StaticResource StatusChipText}"
                                                                   Foreground="White"
                                                                   Text="{Binding StatusText}" />
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>

                            <Expander Grid.Row="8"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="3"
                                      Margin="0,4,0,0"
                                      FontSize="14.5"
                                      FontWeight="SemiBold"
                                      Foreground="#334155"
                                      Header="Show Raw Payloads">
                                <Grid Margin="0,14,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Cookie JWT Payload" />
                                        <controls:JsonViewer Margin="0,10,0,0"
                                                             MinHeight="220"
                                                             ExpirationInfo="{Binding CompareCookieExpirationInfo, Mode=OneWay}"
                                                             JsonText="{Binding CompareCookiePayload, Mode=OneWay}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="JWT Payload (Encrypted)" />
                                        <controls:JsonViewer Margin="0,10,0,0"
                                                             MinHeight="220"
                                                             ExpirationInfo="{Binding CompareAuthExpirationInfo, Mode=OneWay}"
                                                             JsonText="{Binding CompareAuthPayloadEncrypted, Mode=OneWay}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="4"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="3"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Left">
                                        <Button MinWidth="164"
                                                Margin="0,0,12,0"
                                                Style="{StaticResource SecondaryButton}"
                                                IsEnabled="{Binding CanCopyCompareCookieJson}"
                                                Click="CopyCompareCookieButton_Click"
                                                Content="Copy Cookie Payload" />
                                        <Button MinWidth="168"
                                                Margin="0,0,12,0"
                                                Style="{StaticResource SecondaryButton}"
                                                IsEnabled="{Binding CanCopyCompareJson}"
                                                Click="CopyCompareAuthButton_Click"
                                                Content="Copy Auth Payload" />
                                        <Button MinWidth="132"
                                                Style="{StaticResource SubtleButton}"
                                                IsEnabled="{Binding CanCopyCompareDiff}"
                                                Click="CopyCompareDiffButton_Click"
                                                Content="Copy Diff" />
                                    </StackPanel>
                                </Grid>
                            </Expander>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Decrypt ENC">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <controls:FloatingLabelTextBox Height="160"
                                                               Label="ENC Value"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding PayloadInput, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <controls:FloatingLabelTextBox Height="64"
                                                               Label="Encryption Key"
                                                               Text="{Binding PayloadEncryptionKey, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Margin="2,8,0,0"
                                            Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource BodyText}"
                                               FontSize="13"
                                               Foreground="#64748B"
                                               VerticalAlignment="Center"
                                               Text="{Binding PayloadKeySource}" />
                                    <Border Style="{StaticResource InfoBadge}"
                                            Margin="8,0,0,0">
                                        <Border.ToolTip>
                                            <ToolTip Style="{StaticResource GuidanceToolTip}">
                                                <TextBlock TextWrapping="Wrap">
                                                    <Run FontWeight="SemiBold" Text="ENC shortcut:" />
                                                    <Run Text=" paste the full URL containing " />
                                                    <Run FontWeight="SemiBold" Text="ENC" />
                                                    <Run Text=" into Analyze Input instead of manually extracting the ENC value. Leave Encryption Key blank to use " />
                                                    <Run FontWeight="SemiBold" Text="TOK_ENCRYPTION_KEY" />
                                                    <Run Text="." />
                                                </TextBlock>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource InfoBadgeText}" />
                                    </Border>
                                </StackPanel>
                                <Button Margin="0,18,0,0"
                                        Style="{StaticResource PrimaryButton}"
                                        IsEnabled="{Binding CanDecryptPayload}"
                                        Click="PayloadDecryptButton_Click"
                                        Content="{Binding PayloadActionText}" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Decrypted ENC" />
                                <controls:JsonViewer Margin="0,10,0,0"
                                                     MinHeight="360"
                                                     ViewerFontFamily="Segoe UI"
                                                     ViewerFontSize="14"
                                                     JsonText="{Binding PayloadOutput, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="6"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left">
                                <Button MinWidth="150"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource SecondaryButton}"
                                        IsEnabled="{Binding CanCopyPayload}"
                                        Click="CopyPayloadButton_Click"
                                        Content="Copy Result" />
                                <Button MinWidth="140"
                                        Style="{StaticResource SubtleButton}"
                                        IsEnabled="{Binding CanClearPayload}"
                                        Click="ClearPayloadButton_Click"
                                        Content="Clear Input" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Verify JWT">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <controls:FloatingLabelTextBox Height="130"
                                                               Label="JWT"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding JwtValidateInput, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <controls:FloatingLabelTextBox Height="130"
                                                               Label="Signing Key"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               HorizontalScrollBarVisibility="Auto"
                                                               Text="{Binding JwtValidateKey, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Margin="2,8,0,0"
                                            Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource BodyText}"
                                               FontSize="13"
                                               Foreground="#64748B"
                                               VerticalAlignment="Center"
                                               Text="{Binding JwtValidateKeySource}" />
                                    <Border Style="{StaticResource InfoBadge}"
                                            Margin="8,0,0,0">
                                        <Border.ToolTip>
                                            <ToolTip Style="{StaticResource GuidanceToolTip}">
                                                <TextBlock TextWrapping="Wrap">
                                                    <Run FontWeight="SemiBold" Text="Verification note:" />
                                                    <Run Text=" the signing key is always entered manually on this tab. Unlike cookie fingerprints and payload keys, there is no env-var fallback here." />
                                                </TextBlock>
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <TextBlock Style="{StaticResource InfoBadgeText}" />
                                    </Border>
                                </StackPanel>
                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Style="{StaticResource PrimaryButton}"
                                            IsEnabled="{Binding CanValidateJwt}"
                                            Click="JwtValidateButton_Click"
                                            Content="{Binding ValidateActionText}" />

                                    <Border Grid.Column="2"
                                            Style="{StaticResource StatusPill}"
                                            Padding="18,10"
                                            Background="{Binding JwtValidateBadgeBrush}"
                                            VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource StatusPillText}"
                                                   Foreground="{Binding LightTextBrushValue}"
                                                   Text="{Binding JwtValidateBadgeText}" />
                                    </Border>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Verification Result" />
                                <Border Margin="0,10,0,0"
                                        MinHeight="160"
                                        MaxHeight="220"
                                        Padding="18,16"
                                        Background="{StaticResource InputBackgroundBrush}"
                                        BorderBrush="{StaticResource InputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <TextBlock Style="{StaticResource BodyText}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1F2937"
                                                   LineHeight="24"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding JwtValidateSummary, Mode=OneWay}" />
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Raw Input">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Style="{StaticResource SectionTitle}"
                                       Text="Raw input that could not be classified" />

                            <TextBox Grid.Row="2"
                                     MinHeight="420"
                                     Style="{StaticResource CodeBox}"
                                     IsReadOnly="True"
                                     Text="{Binding RawInput, Mode=OneWay}" />
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
