<Window x:Class="DecryptTool.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tok UI"
        Icon="Assets/tok-ui.png"
        Width="1180"
        Height="820"
        MinWidth="1020"
        MinHeight="740"
        FontFamily="Segoe UI"
        FontSize="14"
        Background="#EEE7DA">
    <Window.Resources>
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#22322E" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#22322E" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#22322E" />
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="#CBBEA7" />
            <Setter Property="Background" Value="#FFFDFC" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>
        <Style x:Key="CodeBox" TargetType="TextBox" BasedOn="{StaticResource InputBox}">
            <Setter Property="FontFamily" Value="Cascadia Code" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="AcceptsReturn" Value="True" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Background" Value="#BE5A38" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <DataTemplate x:Key="IconButtonContentTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           FontSize="15"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                           Text="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Tag}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                           Text="{Binding}" />
            </StackPanel>
        </DataTemplate>
        <Style x:Key="IconPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="ContentTemplate" Value="{StaticResource IconButtonContentTemplate}" />
        </Style>
        <Style x:Key="IconSecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Background" Value="#355C54" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="ContentTemplate" Value="{StaticResource IconButtonContentTemplate}" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="22"
                CornerRadius="22"
                Background="#173B37">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="54"
                                Height="54"
                                Margin="0,0,14,0"
                                CornerRadius="27"
                                Background="#F8F2E8">
                            <Image Width="38"
                                   Height="38"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Source="Assets/tok-ui.png" />
                        </Border>
                        <StackPanel>
                            <TextBlock FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="#F8F2E8"
                                       Text="Tok UI" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="15"
                                       Foreground="#D0E1DB"
                                       Text="QA-ready token inspection and troubleshooting" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0"
                               FontSize="15"
                               Foreground="#D0E1DB"
                               Text="Inspect, validate, decrypt, and compare tokens without leaving the desktop app." />
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="14,8"
                        CornerRadius="16"
                        Background="{Binding StatusBrush}"
                        VerticalAlignment="Top">
                    <TextBlock FontWeight="SemiBold"
                               FontSize="15"
                               Foreground="{Binding LightTextBrushValue}"
                               Text="{Binding StatusText}" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="18"
                CornerRadius="20"
                Background="#FFFDFC">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="170" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Auto-detect input" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource BodyText}"
                               Foreground="#5B6D68"
                               Text="Paste a JWT, cookie, or encrypted payload and the UI will route it to the right tab." />
                    <TextBox Margin="0,12,0,0"
                             Height="96"
                             Style="{StaticResource InputBox}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Text="{Binding AutoDetectInput, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <Button Grid.Column="2"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource IconPrimaryButton}"
                        Tag="&#xE721;"
                        Click="AutoDetectButton_Click"
                        Content="Analyze Input" />
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Padding="18"
                CornerRadius="22"
                Background="#FFFDFC">
            <TabControl SelectedIndex="{Binding SelectedTabIndex}">
                <TabItem Header="🔓 Decode Cookie">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Encrypted Cookie" />
                                <TextBox Margin="0,8,0,0"
                                         Height="140"
                                         Style="{StaticResource InputBox}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Text="{Binding CookieInput, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Fingerprint" />
                                <TextBox Margin="0,8,0,0"
                                         Height="40"
                                         Style="{StaticResource InputBox}"
                                         Text="{Binding Fingerprint, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,14,0,0" Style="{StaticResource FieldLabel}" Text="Environment" />
                                <ComboBox Margin="0,8,0,0"
                                          Height="40"
                                          FontSize="15"
                                          ItemsSource="{Binding Environments}"
                                          SelectedItem="{Binding SelectedEnvironment}" />
                                <Button Margin="0,18,0,0"
                                        Style="{StaticResource IconPrimaryButton}"
                                        Tag="&#xE785;"
                                        IsEnabled="{Binding CanDecryptCookie}"
                                        Click="CookieDecryptButton_Click"
                                        Content="{Binding CookieActionText}" />
                                <Button Margin="0,12,0,0"
                                        Height="42"
                                        Style="{StaticResource IconSecondaryButton}"
                                        Tag="&#xE9D2;"
                                        IsEnabled="{Binding CanSendCookieToCompare}"
                                        Click="SendCookieToCompareButton_Click"
                                        Content="Compare with Auth Token" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Output (JSON)" />
                                <TextBox Margin="0,10,0,0"
                                         MinHeight="320"
                                         Style="{StaticResource CodeBox}"
                                         IsReadOnly="True"
                                         Text="{Binding CookieOutput, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="🔍 View Token">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Token Input" />
                                    <TextBox Margin="0,8,0,0"
                                             Height="110"
                                             Style="{StaticResource InputBox}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Text="{Binding JwtInspectInput, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Encryption Key" />
                                    <TextBox Margin="0,8,0,0"
                                             Height="40"
                                             Style="{StaticResource InputBox}"
                                             Text="{Binding JwtInspectEncryptionKey, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource BodyText}"
                                               Foreground="#5B6D68"
                                               Text="{Binding JwtInspectKeySource}" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>

                                <Button Width="148"
                                        Style="{StaticResource IconPrimaryButton}"
                                        Tag="&#xE8A5;"
                                        IsEnabled="{Binding CanInspectJwt}"
                                        Click="JwtInspectButton_Click"
                                        Content="{Binding InspectActionText}" />

                                <Button Grid.Column="2"
                                        Width="176"
                                        Height="42"
                                        Style="{StaticResource IconSecondaryButton}"
                                        Tag="&#xE9D2;"
                                        IsEnabled="{Binding CanSendInspectToCompare}"
                                        Click="SendInspectToCompareButton_Click"
                                        Content="Send to Compare" />

                                <Border Grid.Column="5"
                                        Padding="14,8"
                                        CornerRadius="16"
                                        Background="{Binding JwtInspectExpiryBadgeBrush}"
                                        VerticalAlignment="Center">
                                    <TextBlock FontWeight="SemiBold"
                                               FontSize="15"
                                               Foreground="{Binding LightTextBrushValue}"
                                               Text="{Binding JwtInspectExpiryBadgeText}" />
                                </Border>
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.72*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Style="{StaticResource BodyText}"
                                               Foreground="#5B6D68"
                                               Text="{Binding JwtInspectExpiryDetail}" />
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Header" />
                                    <TextBox Margin="0,10,0,0"
                                             MinHeight="240"
                                             Style="{StaticResource CodeBox}"
                                             IsReadOnly="True"
                                             Text="{Binding JwtInspectHeader, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Current JWT Payload" />
                                    <TextBox Margin="0,10,0,0"
                                             MinHeight="240"
                                             Style="{StaticResource CodeBox}"
                                             IsReadOnly="True"
                                             Text="{Binding JwtInspectPayload, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="4">
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Decrypted Claim Values" />
                                    <TextBox Margin="0,10,0,0"
                                             MinHeight="240"
                                             Style="{StaticResource CodeBox}"
                                             IsReadOnly="True"
                                             Text="{Binding JwtInspectDecryptedPayload, Mode=OneWay}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="🧩 Decode Payload">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Encrypted Payload" />
                                <TextBox Margin="0,8,0,0"
                                         Height="160"
                                         Style="{StaticResource InputBox}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Text="{Binding PayloadInput, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Encryption Key" />
                                <TextBox Margin="0,8,0,0"
                                         Height="40"
                                         Style="{StaticResource InputBox}"
                                         Text="{Binding PayloadEncryptionKey, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource BodyText}"
                                           Foreground="#5B6D68"
                                           Text="{Binding PayloadKeySource}" />
                                <Button Margin="0,18,0,0"
                                        Style="{StaticResource IconPrimaryButton}"
                                        Tag="&#xEA86;"
                                        IsEnabled="{Binding CanDecryptPayload}"
                                        Click="PayloadDecryptButton_Click"
                                        Content="{Binding PayloadActionText}" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Decrypted Payload" />
                                <TextBox Margin="0,10,0,0"
                                         MinHeight="360"
                                         Style="{StaticResource CodeBox}"
                                         IsReadOnly="True"
                                         Text="{Binding PayloadOutput, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="6"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left">
                                <Button Width="120"
                                        Height="38"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource IconSecondaryButton}"
                                        Tag="&#xE8C8;"
                                        IsEnabled="{Binding CanCopyPayload}"
                                        Click="CopyPayloadButton_Click"
                                        Content="Copy Result" />
                                <Button Width="120"
                                        Height="38"
                                        Background="#D5C4A1"
                                        Foreground="#22322E"
                                        BorderThickness="0"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        ContentTemplate="{StaticResource IconButtonContentTemplate}"
                                        Tag="&#xE894;"
                                        IsEnabled="{Binding CanClearPayload}"
                                        Click="ClearPayloadButton_Click"
                                        Content="Clear Input" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="⚖️ Compare Tokens">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Cookie JWT / Encrypted Cookie" />
                                <TextBox Margin="0,8,0,0"
                                         Height="110"
                                         Style="{StaticResource InputBox}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Text="{Binding CompareCookieJwt, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,14,0,0"
                                           Style="{StaticResource FieldLabel}"
                                           Text="Auth JWT" />
                                <TextBox Margin="0,8,0,0"
                                         Height="110"
                                         Style="{StaticResource InputBox}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Text="{Binding CompareAuthJwt, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Fingerprint" />
                                <TextBox Margin="0,8,0,0"
                                         Height="40"
                                         Style="{StaticResource InputBox}"
                                         Text="{Binding Fingerprint, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,14,0,0" Style="{StaticResource FieldLabel}" Text="Environment" />
                                <ComboBox Margin="0,8,0,0"
                                          Height="40"
                                          FontSize="15"
                                          ItemsSource="{Binding Environments}"
                                          SelectedItem="{Binding SelectedEnvironment}" />
                                <Button Margin="0,18,0,0"
                                        Style="{StaticResource IconPrimaryButton}"
                                        Tag="&#xE9D2;"
                                        IsEnabled="{Binding CanCompareTokens}"
                                        Click="CompareTokensButton_Click"
                                        Content="{Binding CompareActionText}" />
                            </StackPanel>

                            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Height="40"
                                         Style="{StaticResource InputBox}"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding CompareSearchText, UpdateSourceTrigger=PropertyChanged}" />

                                <CheckBox Grid.Column="2"
                                          VerticalAlignment="Center"
                                          FontSize="15"
                                          FontWeight="SemiBold"
                                          Foreground="#22322E"
                                          IsChecked="{Binding ShowDifferencesOnly}"
                                          Content="Show Differences Only" />
                            </Grid>

                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Claim Comparison" />
                                <DataGrid Margin="0,10,0,0"
                                          MinHeight="280"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="Column"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          GridLinesVisibility="Horizontal"
                                          RowBackground="#FFFDFC"
                                          AlternatingRowBackground="#F6F0E5"
                                          BorderBrush="#CBBEA7"
                                          ItemsSource="{Binding CompareRows}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Claim" Binding="{Binding Claim}" Width="1.2*" />
                                        <DataGridTextColumn Header="Cookie (Clear)" Binding="{Binding CookieValue}" Width="1.6*" />
                                        <DataGridTextColumn Header="Auth (Decrypted)" Binding="{Binding AuthValue}" Width="1.6*" />
                                        <DataGridTemplateColumn Header="Status" Width="160">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8,4"
                                                            CornerRadius="12"
                                                            Background="{Binding StatusBrush}"
                                                            HorizontalAlignment="Left">
                                                        <TextBlock Foreground="White"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding StatusText}" />
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>

                            <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="3"
                                           Style="{StaticResource SectionTitle}"
                                           Text="Auth Payload Views" />

                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Auth Payload (Encrypted)" />
                                    <TextBox Margin="0,10,0,0"
                                             MinHeight="220"
                                             Style="{StaticResource CodeBox}"
                                             IsReadOnly="True"
                                             Text="{Binding CompareAuthPayloadEncrypted, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Auth Payload (Decrypted)" />
                                    <TextBox Margin="0,10,0,0"
                                             MinHeight="220"
                                             Style="{StaticResource CodeBox}"
                                             IsReadOnly="True"
                                             Text="{Binding CompareAuthPayloadDecrypted, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel Grid.Row="4"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="3"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Left">
                                    <Button Width="140"
                                            Height="38"
                                            Margin="0,0,12,0"
                                            Style="{StaticResource IconSecondaryButton}"
                                            Tag="&#xE8C8;"
                                            IsEnabled="{Binding CanCopyCompareCookieJson}"
                                            Click="CopyCompareCookieButton_Click"
                                            Content="Copy Cookie JSON" />
                                    <Button Width="140"
                                            Height="38"
                                            Margin="0,0,12,0"
                                            Style="{StaticResource IconSecondaryButton}"
                                            Tag="&#xE8C8;"
                                            IsEnabled="{Binding CanCopyCompareJson}"
                                            Click="CopyCompareAuthButton_Click"
                                            Content="Copy Auth JSON" />
                                    <Button Width="140"
                                            Height="38"
                                            Background="#D5C4A1"
                                            Foreground="#22322E"
                                            BorderThickness="0"
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            ContentTemplate="{StaticResource IconButtonContentTemplate}"
                                            Tag="&#xE8C8;"
                                            IsEnabled="{Binding CanCopyCompareDiff}"
                                            Click="CopyCompareDiffButton_Click"
                                            Content="Copy Diff" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="✅ Verify Token">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Token Input" />
                                <TextBox Margin="0,8,0,0"
                                         Height="130"
                                         Style="{StaticResource InputBox}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Text="{Binding JwtValidateInput, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Signing Key" />
                                <TextBox Margin="0,8,0,0"
                                         Height="130"
                                         Style="{StaticResource CodeBox}"
                                         Text="{Binding JwtValidateKey, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource BodyText}"
                                           Foreground="#5B6D68"
                                           Text="{Binding JwtValidateKeySource}" />
                                <Button Margin="0,18,0,0"
                                        Style="{StaticResource IconPrimaryButton}"
                                        Tag="&#xE73E;"
                                        IsEnabled="{Binding CanValidateJwt}"
                                        Click="JwtValidateButton_Click"
                                        Content="{Binding ValidateActionText}" />
                            </StackPanel>

                            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                                <Border Padding="14,8"
                                        CornerRadius="16"
                                        Background="{Binding JwtValidateBadgeBrush}">
                                    <TextBlock FontWeight="SemiBold"
                                               FontSize="15"
                                               Foreground="{Binding LightTextBrushValue}"
                                               Text="{Binding JwtValidateBadgeText}" />
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Validation Result" />
                                <TextBox Margin="0,10,0,0"
                                         MinHeight="340"
                                         Style="{StaticResource CodeBox}"
                                         IsReadOnly="True"
                                         Text="{Binding JwtValidateSummary, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
