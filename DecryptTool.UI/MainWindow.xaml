<Window x:Class="DecryptTool.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DecryptTool.UI.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tok UI"
        Icon="Assets/tok-ui.png"
        Width="1180"
        Height="820"
        MinWidth="1020"
        MinHeight="740"
        FontFamily="Segoe UI"
        FontSize="14"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#22322E" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#22322E" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#22322E" />
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>
        <Style x:Key="CodeBox" TargetType="TextBox" BasedOn="{StaticResource InputBox}">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="AcceptsReturn" Value="True" />
        </Style>
        <DataTemplate x:Key="IconButtonContentTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           FontSize="15"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                           Text="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Tag}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                           Text="{Binding}" />
            </StackPanel>
        </DataTemplate>
        <Style x:Key="IconPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="ContentTemplate" Value="{StaticResource IconButtonContentTemplate}" />
        </Style>
        <Style x:Key="IconSecondaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="ContentTemplate" Value="{StaticResource IconButtonContentTemplate}" />
        </Style>
        <Style x:Key="IconSubtleButton" TargetType="Button" BasedOn="{StaticResource SubtleButton}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="ContentTemplate" Value="{StaticResource IconButtonContentTemplate}" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="54"
                                Height="54"
                                Margin="0,0,14,0"
                                CornerRadius="27"
                                Background="#DBEAFE">
                            <Image Width="38"
                                   Height="38"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Source="Assets/tok-ui.png" />
                        </Border>
                        <StackPanel>
                            <TextBlock FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Text="Tok UI" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="15"
                                       Foreground="#4B5563"
                                       Text="QA-ready token inspection, comparison, and troubleshooting" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Border Style="{StaticResource StatusPill}"
                            Background="{Binding StatusBrush}"
                            VerticalAlignment="Top">
                        <TextBlock Style="{StaticResource StatusPillText}"
                                   Foreground="{Binding LightTextBrushValue}"
                                   Text="{Binding StatusText}" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="170" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource SectionTitle}"
                               Text="Auto-detect: paste a JWT, cookie, or encrypted payload." />
                    <controls:FloatingLabelTextBox Height="96"
                                                   Label="Paste or drop a value"
                                                   AcceptsReturn="True"
                                                   TextWrapping="Wrap"
                                                   VerticalScrollBarVisibility="Auto"
                                                   Text="{Binding AutoDetectInput, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <Button Grid.Column="2"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource PrimaryButton}"
                        Click="AutoDetectButton_Click"
                        Content="Analyze Input" />
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Style="{StaticResource CardStyle}"
                Padding="24">
            <TabControl SelectedIndex="{Binding SelectedTabIndex}">
                <TabItem Header="Cookie">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <controls:FloatingLabelTextBox Height="140"
                                                               Label="Encrypted Cookie"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding CookieInput, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <controls:FloatingLabelTextBox Height="64"
                                                               Label="Fingerprint"
                                                               Text="{Binding Fingerprint, UpdateSourceTrigger=PropertyChanged}" />
                                <controls:FloatingLabelComboBox Height="64"
                                                                Label="Environment"
                                                                ItemsSource="{Binding Environments}"
                                                                SelectedItem="{Binding SelectedEnvironment}" />
                                <Button Margin="0,18,0,0"
                                        Style="{StaticResource PrimaryButton}"
                                        IsEnabled="{Binding CanDecryptCookie}"
                                        Click="CookieDecryptButton_Click"
                                        Content="{Binding CookieActionText}" />
                                <Button Margin="0,12,0,0"
                                        Style="{StaticResource SecondaryButton}"
                                        IsEnabled="{Binding CanSendCookieToCompare}"
                                        Click="SendCookieToCompareButton_Click"
                                        Content="Compare with Auth Token" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Output (JSON)" />
                                <controls:JsonViewer Margin="0,10,0,0"
                                                     MinHeight="320"
                                                     JsonText="{Binding CookieOutput, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Inspect JWT">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <controls:FloatingLabelTextBox Height="110"
                                                                   Label="Token Input"
                                                                   AcceptsReturn="True"
                                                                   TextWrapping="Wrap"
                                                                   VerticalScrollBarVisibility="Auto"
                                                                   Text="{Binding JwtInspectInput, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <controls:FloatingLabelTextBox Height="64"
                                                                   Label="Encryption Key"
                                                                   Text="{Binding JwtInspectEncryptionKey, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="2,8,0,0"
                                               Style="{StaticResource BodyText}"
                                               FontSize="13"
                                               Foreground="#64748B"
                                               Text="{Binding JwtInspectKeySource}" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>

                                <Button MinWidth="168"
                                        Style="{StaticResource PrimaryButton}"
                                        IsEnabled="{Binding CanInspectJwt}"
                                        Click="JwtInspectButton_Click"
                                        Content="{Binding InspectActionText}" />

                                <Button Grid.Column="2"
                                        MinWidth="192"
                                        Style="{StaticResource SecondaryButton}"
                                        IsEnabled="{Binding CanSendInspectToCompare}"
                                        Click="SendInspectToCompareButton_Click"
                                        Content="Send to Compare" />

                                <Border Grid.Column="5"
                                        Style="{StaticResource StatusPill}"
                                        Background="{Binding JwtInspectExpiryBadgeBrush}"
                                        VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource StatusPillText}"
                                               Foreground="{Binding LightTextBrushValue}"
                                               Text="{Binding JwtInspectExpiryBadgeText}" />
                                </Border>
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.72*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Style="{StaticResource BodyText}"
                                               Foreground="#5B6D68"
                                               Text="{Binding JwtInspectExpiryDetail}" />
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Header" />
                                    <controls:JsonViewer Margin="0,10,0,0"
                                                         MinHeight="240"
                                                         JsonText="{Binding JwtInspectHeader, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Current JWT Payload" />
                                    <controls:JsonViewer Margin="0,10,0,0"
                                                         MinHeight="240"
                                                         JsonText="{Binding JwtInspectPayload, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="4">
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Decrypted Claim Values" />
                                    <controls:JsonViewer Margin="0,10,0,0"
                                                         MinHeight="240"
                                                         JsonText="{Binding JwtInspectDecryptedPayload, Mode=OneWay}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Payload">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <controls:FloatingLabelTextBox Height="160"
                                                               Label="Encrypted Payload"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding PayloadInput, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <controls:FloatingLabelTextBox Height="64"
                                                               Label="Encryption Key"
                                                               Text="{Binding PayloadEncryptionKey, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="2,8,0,0"
                                           Style="{StaticResource BodyText}"
                                           FontSize="13"
                                           Foreground="#64748B"
                                           Text="{Binding PayloadKeySource}" />
                                <Button Margin="0,18,0,0"
                                        Style="{StaticResource PrimaryButton}"
                                        IsEnabled="{Binding CanDecryptPayload}"
                                        Click="PayloadDecryptButton_Click"
                                        Content="{Binding PayloadActionText}" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Decrypted Payload" />
                                <controls:JsonViewer Margin="0,10,0,0"
                                                     MinHeight="360"
                                                     JsonText="{Binding PayloadOutput, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="6"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left">
                                <Button MinWidth="150"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource SecondaryButton}"
                                        IsEnabled="{Binding CanCopyPayload}"
                                        Click="CopyPayloadButton_Click"
                                        Content="Copy Result" />
                                <Button MinWidth="140"
                                        Style="{StaticResource SubtleButton}"
                                        IsEnabled="{Binding CanClearPayload}"
                                        Click="ClearPayloadButton_Click"
                                        Content="Clear Input" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Compare">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <controls:FloatingLabelTextBox Height="110"
                                                               Label="Cookie JWT / Encrypted Cookie"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding CompareCookieJwt, UpdateSourceTrigger=PropertyChanged}" />

                                <controls:FloatingLabelTextBox Height="110"
                                                               Label="Auth JWT"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding CompareAuthJwt, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <controls:FloatingLabelTextBox Height="64"
                                                               Label="Fingerprint"
                                                               Text="{Binding Fingerprint, UpdateSourceTrigger=PropertyChanged}" />
                                <controls:FloatingLabelComboBox Height="64"
                                                                Label="Environment"
                                                                ItemsSource="{Binding Environments}"
                                                                SelectedItem="{Binding SelectedEnvironment}" />
                                <Button Margin="0,18,0,0"
                                        Style="{StaticResource PrimaryButton}"
                                        IsEnabled="{Binding CanCompareTokens}"
                                        Click="CompareTokensButton_Click"
                                        Content="{Binding CompareActionText}" />
                            </StackPanel>

                            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                                <CheckBox HorizontalAlignment="Right"
                                          IsChecked="{Binding ShowDifferencesOnly}"
                                          Content="Show Differences Only" />
                            </Grid>

                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Claim Comparison" />
                                <DataGrid Margin="0,10,0,0"
                                          MinHeight="280"
                                          AutoGenerateColumns="False"
                                          ItemsSource="{Binding CompareRows}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Claim"
                                                            Binding="{Binding Claim}"
                                                            Width="0.82*"
                                                            ElementStyle="{StaticResource CompareGridText}" />
                                        <DataGridTextColumn Header="Cookie"
                                                            Binding="{Binding CookieValue}"
                                                            Width="1.18*"
                                                            ElementStyle="{StaticResource CompareGridText}" />
                                        <DataGridTextColumn Header="Auth Raw"
                                                            Binding="{Binding AuthEncryptedValue}"
                                                            Width="1.18*"
                                                            ElementStyle="{StaticResource CompareGridText}" />
                                        <DataGridTextColumn Header="Auth Clear"
                                                            Binding="{Binding AuthValue}"
                                                            Width="1.18*"
                                                            ElementStyle="{StaticResource CompareGridText}" />
                                        <DataGridTemplateColumn Header="Status"
                                                                Width="96"
                                                                HeaderStyle="{StaticResource CompareStatusHeader}"
                                                                CellStyle="{StaticResource CompareStatusCell}">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource StatusChip}"
                                                            Background="{Binding StatusBrush}"
                                                            HorizontalAlignment="Center">
                                                        <TextBlock Style="{StaticResource StatusChipText}"
                                                                   Foreground="White"
                                                                   Text="{Binding StatusText}" />
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>

                            <Expander Grid.Row="6"
                                      Grid.Column="0"
                                      Grid.ColumnSpan="3"
                                      Margin="0,4,0,0"
                                      FontSize="14.5"
                                      FontWeight="SemiBold"
                                      Foreground="#334155"
                                      Header="Show Raw Payloads">
                                <Grid Margin="0,14,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Cookie JWT Payload" />
                                        <controls:JsonViewer Margin="0,10,0,0"
                                                             MinHeight="220"
                                                             JsonText="{Binding CompareCookiePayload, Mode=OneWay}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Auth JWT Payload (Encrypted)" />
                                        <controls:JsonViewer Margin="0,10,0,0"
                                                             MinHeight="220"
                                                             JsonText="{Binding CompareAuthPayloadEncrypted, Mode=OneWay}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="4"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="3"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Left">
                                        <Button MinWidth="164"
                                                Margin="0,0,12,0"
                                                Style="{StaticResource SecondaryButton}"
                                                IsEnabled="{Binding CanCopyCompareCookieJson}"
                                                Click="CopyCompareCookieButton_Click"
                                                Content="Copy Cookie Payload" />
                                        <Button MinWidth="168"
                                                Margin="0,0,12,0"
                                                Style="{StaticResource SecondaryButton}"
                                                IsEnabled="{Binding CanCopyCompareJson}"
                                                Click="CopyCompareAuthButton_Click"
                                                Content="Copy Auth Payload" />
                                        <Button MinWidth="132"
                                                Style="{StaticResource SubtleButton}"
                                                IsEnabled="{Binding CanCopyCompareDiff}"
                                                Click="CopyCompareDiffButton_Click"
                                                Content="Copy Diff" />
                                    </StackPanel>
                                </Grid>
                            </Expander>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Validate">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <controls:FloatingLabelTextBox Height="130"
                                                               Label="Token Input"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding JwtValidateInput, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <controls:FloatingLabelTextBox Height="130"
                                                               Label="Signing Key"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               HorizontalScrollBarVisibility="Auto"
                                                               InputFontFamily="Consolas"
                                                               InputFontSize="12.5"
                                                               Text="{Binding JwtValidateKey, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="2,8,0,0"
                                           Style="{StaticResource BodyText}"
                                           FontSize="13"
                                           Foreground="#64748B"
                                           Text="{Binding JwtValidateKeySource}" />
                                <Button Margin="0,18,0,0"
                                        Style="{StaticResource PrimaryButton}"
                                        IsEnabled="{Binding CanValidateJwt}"
                                        Click="JwtValidateButton_Click"
                                        Content="{Binding ValidateActionText}" />
                            </StackPanel>

                            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                                <Border Style="{StaticResource StatusPill}"
                                        Background="{Binding JwtValidateBadgeBrush}">
                                    <TextBlock Style="{StaticResource StatusPillText}"
                                               Foreground="{Binding LightTextBrushValue}"
                                               Text="{Binding JwtValidateBadgeText}" />
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Validation Result" />
                                <TextBox Margin="0,10,0,0"
                                         MinHeight="340"
                                         Style="{StaticResource CodeBox}"
                                         IsReadOnly="True"
                                         Text="{Binding JwtValidateSummary, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
