<Window x:Class="DecryptTool.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DecryptTool.UI.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tok UI"
        Icon="Assets/tok-ui.png"
        Width="1180"
        Height="820"
        MinWidth="1020"
        MinHeight="740"
        FontFamily="Segoe UI"
        FontSize="14"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#22322E" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#22322E" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#22322E" />
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>
        <Style x:Key="CodeBox" TargetType="TextBox" BasedOn="{StaticResource InputBox}">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="AcceptsReturn" Value="True" />
        </Style>
        <DataTemplate x:Key="IconButtonContentTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           FontSize="15"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                           Text="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Tag}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                           Text="{Binding}" />
            </StackPanel>
        </DataTemplate>
        <Style x:Key="IconPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="ContentTemplate" Value="{StaticResource IconButtonContentTemplate}" />
        </Style>
        <Style x:Key="IconSecondaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="ContentTemplate" Value="{StaticResource IconButtonContentTemplate}" />
        </Style>
        <Style x:Key="IconSubtleButton" TargetType="Button" BasedOn="{StaticResource SubtleButton}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="ContentTemplate" Value="{StaticResource IconButtonContentTemplate}" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="54"
                                Height="54"
                                Margin="0,0,14,0"
                                CornerRadius="27"
                                Background="#DBEAFE">
                            <Image Width="38"
                                   Height="38"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Source="Assets/tok-ui.png" />
                        </Border>
                        <StackPanel>
                            <TextBlock FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"
                                       Text="Tok UI" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="15"
                                       Foreground="#4B5563"
                                       Text="QA-ready token inspection and troubleshooting" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0"
                               FontSize="15"
                               Foreground="#6B7280"
                               Text="Inspect, validate, decrypt, and compare tokens without leaving the desktop app." />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Border Padding="14,8"
                            CornerRadius="16"
                            Background="{Binding StatusBrush}"
                            VerticalAlignment="Top">
                        <TextBlock FontWeight="SemiBold"
                                   FontSize="15"
                                   Foreground="{Binding LightTextBrushValue}"
                                   Text="{Binding StatusText}" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="170" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Auto-detect input" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource BodyText}"
                               Foreground="#5B6D68"
                               Text="Paste a JWT, cookie, or encrypted payload and the UI will route it to the right tab." />
                    <controls:FloatingLabelTextBox Height="96"
                                                   Label="Paste or drop a value"
                                                   AcceptsReturn="True"
                                                   TextWrapping="Wrap"
                                                   VerticalScrollBarVisibility="Auto"
                                                   Text="{Binding AutoDetectInput, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <Button Grid.Column="2"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource IconPrimaryButton}"
                        Tag="&#xE721;"
                        Click="AutoDetectButton_Click"
                        Content="Analyze Input" />
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Style="{StaticResource CardStyle}"
                Padding="18">
            <TabControl SelectedIndex="{Binding SelectedTabIndex}">
                <TabItem Header="🔓 Decode Cookie">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <controls:FloatingLabelTextBox Height="140"
                                                               Label="Encrypted Cookie"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding CookieInput, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <controls:FloatingLabelTextBox Height="56"
                                                               Label="Fingerprint"
                                                               Text="{Binding Fingerprint, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,14,0,0" Style="{StaticResource FieldLabel}" Text="Environment" />
                                <ComboBox Margin="0,8,0,0"
                                          Height="40"
                                          FontSize="15"
                                          ItemsSource="{Binding Environments}"
                                          SelectedItem="{Binding SelectedEnvironment}" />
                                <Button Margin="0,18,0,0"
                                        Style="{StaticResource IconPrimaryButton}"
                                        Tag="&#xE785;"
                                        IsEnabled="{Binding CanDecryptCookie}"
                                        Click="CookieDecryptButton_Click"
                                        Content="{Binding CookieActionText}" />
                                <Button Margin="0,12,0,0"
                                        Height="42"
                                        Style="{StaticResource IconSecondaryButton}"
                                        Tag="&#xE9D2;"
                                        IsEnabled="{Binding CanSendCookieToCompare}"
                                        Click="SendCookieToCompareButton_Click"
                                        Content="Compare with Auth Token" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Output (JSON)" />
                                <controls:JsonViewer Margin="0,10,0,0"
                                                     MinHeight="320"
                                                     JsonText="{Binding CookieOutput, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="🔍 View Token">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <controls:FloatingLabelTextBox Height="110"
                                                                   Label="Token Input"
                                                                   AcceptsReturn="True"
                                                                   TextWrapping="Wrap"
                                                                   VerticalScrollBarVisibility="Auto"
                                                                   Text="{Binding JwtInspectInput, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <controls:FloatingLabelTextBox Height="56"
                                                                   Label="Encryption Key"
                                                                   Text="{Binding JwtInspectEncryptionKey, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource BodyText}"
                                               Foreground="#5B6D68"
                                               Text="{Binding JwtInspectKeySource}" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>

                                <Button MinWidth="168"
                                        Style="{StaticResource IconPrimaryButton}"
                                        Tag="&#xE8A5;"
                                        IsEnabled="{Binding CanInspectJwt}"
                                        Click="JwtInspectButton_Click"
                                        Content="{Binding InspectActionText}" />

                                <Button Grid.Column="2"
                                        MinWidth="192"
                                        Height="42"
                                        Style="{StaticResource IconSecondaryButton}"
                                        Tag="&#xE9D2;"
                                        IsEnabled="{Binding CanSendInspectToCompare}"
                                        Click="SendInspectToCompareButton_Click"
                                        Content="Send to Compare" />

                                <Border Grid.Column="5"
                                        Padding="14,8"
                                        CornerRadius="16"
                                        Background="{Binding JwtInspectExpiryBadgeBrush}"
                                        VerticalAlignment="Center">
                                    <TextBlock FontWeight="SemiBold"
                                               FontSize="15"
                                               Foreground="{Binding LightTextBrushValue}"
                                               Text="{Binding JwtInspectExpiryBadgeText}" />
                                </Border>
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.72*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Style="{StaticResource BodyText}"
                                               Foreground="#5B6D68"
                                               Text="{Binding JwtInspectExpiryDetail}" />
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Header" />
                                    <controls:JsonViewer Margin="0,10,0,0"
                                                         MinHeight="240"
                                                         JsonText="{Binding JwtInspectHeader, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Current JWT Payload" />
                                    <controls:JsonViewer Margin="0,10,0,0"
                                                         MinHeight="240"
                                                         JsonText="{Binding JwtInspectPayload, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="4">
                                    <TextBlock Style="{StaticResource SectionTitle}" Text="Decrypted Claim Values" />
                                    <controls:JsonViewer Margin="0,10,0,0"
                                                         MinHeight="240"
                                                         JsonText="{Binding JwtInspectDecryptedPayload, Mode=OneWay}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="🧩 Decode Payload">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <controls:FloatingLabelTextBox Height="160"
                                                               Label="Encrypted Payload"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding PayloadInput, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <controls:FloatingLabelTextBox Height="56"
                                                               Label="Encryption Key"
                                                               Text="{Binding PayloadEncryptionKey, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource BodyText}"
                                           Foreground="#5B6D68"
                                           Text="{Binding PayloadKeySource}" />
                                <Button Margin="0,18,0,0"
                                        Style="{StaticResource IconPrimaryButton}"
                                        Tag="&#xEA86;"
                                        IsEnabled="{Binding CanDecryptPayload}"
                                        Click="PayloadDecryptButton_Click"
                                        Content="{Binding PayloadActionText}" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Decrypted Payload" />
                                <controls:JsonViewer Margin="0,10,0,0"
                                                     MinHeight="360"
                                                     JsonText="{Binding PayloadOutput, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="6"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left">
                                <Button MinWidth="150"
                                        Height="38"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource IconSecondaryButton}"
                                        Tag="&#xE8C8;"
                                        IsEnabled="{Binding CanCopyPayload}"
                                        Click="CopyPayloadButton_Click"
                                        Content="Copy Result" />
                                <Button MinWidth="140"
                                        Height="38"
                                        Style="{StaticResource IconSubtleButton}"
                                        Tag="&#xE894;"
                                        IsEnabled="{Binding CanClearPayload}"
                                        Click="ClearPayloadButton_Click"
                                        Content="Clear Input" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="⚖️ Compare Tokens">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <controls:FloatingLabelTextBox Height="110"
                                                               Label="Cookie JWT / Encrypted Cookie"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding CompareCookieJwt, UpdateSourceTrigger=PropertyChanged}" />

                                <controls:FloatingLabelTextBox Height="110"
                                                               Label="Auth JWT"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding CompareAuthJwt, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <controls:FloatingLabelTextBox Height="56"
                                                               Label="Fingerprint"
                                                               Text="{Binding Fingerprint, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,14,0,0" Style="{StaticResource FieldLabel}" Text="Environment" />
                                <ComboBox Margin="0,8,0,0"
                                          Height="40"
                                          FontSize="15"
                                          ItemsSource="{Binding Environments}"
                                          SelectedItem="{Binding SelectedEnvironment}" />
                                <Button Margin="0,18,0,0"
                                        Style="{StaticResource IconPrimaryButton}"
                                        Tag="&#xE9D2;"
                                        IsEnabled="{Binding CanCompareTokens}"
                                        Click="CompareTokensButton_Click"
                                        Content="{Binding CompareActionText}" />
                            </StackPanel>

                            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <controls:FloatingLabelTextBox Height="56"
                                                               Label="Search claims"
                                                               Text="{Binding CompareSearchText, UpdateSourceTrigger=PropertyChanged}" />

                                <CheckBox Grid.Column="2"
                                          VerticalAlignment="Center"
                                          FontSize="15"
                                          FontWeight="SemiBold"
                                          Foreground="#22322E"
                                          IsChecked="{Binding ShowDifferencesOnly}"
                                          Content="Show Differences Only" />
                            </Grid>

                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Claim Comparison" />
                                <DataGrid Margin="0,10,0,0"
                                          MinHeight="280"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="Column"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          GridLinesVisibility="Horizontal"
                                          RowBackground="#FFFDFC"
                                          AlternatingRowBackground="#F6F0E5"
                                          BorderBrush="#CBBEA7"
                                          ItemsSource="{Binding CompareRows}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Claim" Binding="{Binding Claim}" Width="1.2*" />
                                        <DataGridTextColumn Header="Cookie (Clear)" Binding="{Binding CookieValue}" Width="1.6*" />
                                        <DataGridTextColumn Header="Auth (Decrypted)" Binding="{Binding AuthValue}" Width="1.6*" />
                                        <DataGridTemplateColumn Header="Status" Width="160">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8,4"
                                                            CornerRadius="12"
                                                            Background="{Binding StatusBrush}"
                                                            HorizontalAlignment="Left">
                                                        <TextBlock Foreground="White"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding StatusText}" />
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>

                            <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Grid.ColumnSpan="3"
                                           Style="{StaticResource SectionTitle}"
                                           Text="Auth Payload Views" />

                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Auth Payload (Encrypted)" />
                                    <controls:JsonViewer Margin="0,10,0,0"
                                                         MinHeight="220"
                                                         JsonText="{Binding CompareAuthPayloadEncrypted, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Auth Payload (Decrypted)" />
                                    <controls:JsonViewer Margin="0,10,0,0"
                                                         MinHeight="220"
                                                         JsonText="{Binding CompareAuthPayloadDecrypted, Mode=OneWay}" />
                                </StackPanel>

                                <StackPanel Grid.Row="4"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="3"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Left">
                                    <Button MinWidth="160"
                                            Height="38"
                                            Margin="0,0,12,0"
                                            Style="{StaticResource IconSecondaryButton}"
                                            Tag="&#xE8C8;"
                                            IsEnabled="{Binding CanCopyCompareCookieJson}"
                                            Click="CopyCompareCookieButton_Click"
                                            Content="Copy Cookie JSON" />
                                    <Button MinWidth="152"
                                            Height="38"
                                            Margin="0,0,12,0"
                                            Style="{StaticResource IconSecondaryButton}"
                                            Tag="&#xE8C8;"
                                            IsEnabled="{Binding CanCopyCompareJson}"
                                            Click="CopyCompareAuthButton_Click"
                                            Content="Copy Auth JSON" />
                                    <Button MinWidth="132"
                                            Height="38"
                                            Style="{StaticResource IconSubtleButton}"
                                            Tag="&#xE8C8;"
                                            IsEnabled="{Binding CanCopyCompareDiff}"
                                            Click="CopyCompareDiffButton_Click"
                                            Content="Copy Diff" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="✅ Verify Token">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <controls:FloatingLabelTextBox Height="130"
                                                               Label="Token Input"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               Text="{Binding JwtValidateInput, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <controls:FloatingLabelTextBox Height="130"
                                                               Label="Signing Key"
                                                               AcceptsReturn="True"
                                                               TextWrapping="Wrap"
                                                               VerticalScrollBarVisibility="Auto"
                                                               HorizontalScrollBarVisibility="Auto"
                                                               InputFontFamily="Consolas"
                                                               InputFontSize="12.5"
                                                               Text="{Binding JwtValidateKey, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,10,0,0"
                                           Style="{StaticResource BodyText}"
                                           Foreground="#5B6D68"
                                           Text="{Binding JwtValidateKeySource}" />
                                <Button Margin="0,18,0,0"
                                        Style="{StaticResource IconPrimaryButton}"
                                        Tag="&#xE73E;"
                                        IsEnabled="{Binding CanValidateJwt}"
                                        Click="JwtValidateButton_Click"
                                        Content="{Binding ValidateActionText}" />
                            </StackPanel>

                            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                                <Border Padding="14,8"
                                        CornerRadius="16"
                                        Background="{Binding JwtValidateBadgeBrush}">
                                    <TextBlock FontWeight="SemiBold"
                                               FontSize="15"
                                               Foreground="{Binding LightTextBrushValue}"
                                               Text="{Binding JwtValidateBadgeText}" />
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="Validation Result" />
                                <TextBox Margin="0,10,0,0"
                                         MinHeight="340"
                                         Style="{StaticResource CodeBox}"
                                         IsReadOnly="True"
                                         Text="{Binding JwtValidateSummary, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
